local ZygHubV4ESP = {}

ZygHubV4ESP.Settings = {
    Box_Color = Color3.fromRGB(255, 0, 0),
    Tracer_Color = Color3.fromRGB(255, 0, 0),
    Tracer_Thickness = 1,
    Box_Thickness = 1,
    Tracer_Origin = "Bottom",
    Tracer_FollowMouse = false,
    Tracers = true,
    MaxDistance = 1000,

    -- Path set to mobs
    TargetPath = workspace.Entities
}

local player = game:GetService("Players").LocalPlayer
local camera = workspace.CurrentCamera
local mouse = player:GetMouse()

-- Helper: check if string looks like random letters/numbers
local function IsRandomString(str)
    return str:match("%d") or str:match("%u") or str:match("%l")
end

-- Drawing functions (same as your original ESP)
local function NewQuad(thickness, color)
    local quad = Drawing.new("Quad")
    quad.Visible = false
    quad.Color = color
    quad.Thickness = thickness
    quad.Filled = false
    quad.Transparency = 1
    return quad
end

local function NewLine(thickness, color)
    local line = Drawing.new("Line")
    line.Visible = false
    line.Color = color
    line.Thickness = thickness
    line.Transparency = 1
    return line
end

local function Visibility(state, lib)
    for _, obj in pairs(lib) do
        obj.Visible = state
    end
end

-- Core ESP function
local function ESP(entity)
    -- Skip players and local player
    if game:GetService("Players"):FindFirstChild(entity.Name) then return end
    if entity == player.Character then return end
    if not IsRandomString(entity.Name) then return end

    local library = {
        tracer = NewLine(ZygHubV4ESP.Settings.Tracer_Thickness, ZygHubV4ESP.Settings.Tracer_Color),
        box = NewQuad(ZygHubV4ESP.Settings.Box_Thickness, ZygHubV4ESP.Settings.Box_Color),
    }

    local connection
    connection = game:GetService("RunService").RenderStepped:Connect(function()
        if entity and entity:FindFirstChild("HumanoidRootPart") then
            local HumPos, onScreen = camera:WorldToViewportPoint(entity.HumanoidRootPart.Position)
            if onScreen then
                -- Box
                local size = 5
                library.box.PointA = Vector2.new(HumPos.X - size, HumPos.Y - size)
                library.box.PointB = Vector2.new(HumPos.X + size, HumPos.Y - size)
                library.box.PointC = Vector2.new(HumPos.X + size, HumPos.Y + size)
                library.box.PointD = Vector2.new(HumPos.X - size, HumPos.Y + size)

                -- Tracer
                if ZygHubV4ESP.Settings.Tracers then
                    library.tracer.From = Vector2.new(camera.ViewportSize.X * 0.5, camera.ViewportSize.Y)
                    library.tracer.To = Vector2.new(HumPos.X, HumPos.Y)
                end

                -- Colors
                library.box.Color = ZygHubV4ESP.Settings.Box_Color
                library.tracer.Color = ZygHubV4ESP.Settings.Tracer_Color

                Visibility(true, library)
            else
                Visibility(false, library)
            end
        else
            Visibility(false, library)
            if not entity or not entity.Parent then
                connection:Disconnect()
            end
        end
    end)
end

-- Load ESP
function ZygHubV4ESP:LoadESP()
    for _, mob in pairs(self.Settings.TargetPath:GetChildren()) do
        ESP(mob)
    end
    self._addedConnection = self.Settings.TargetPath.ChildAdded:Connect(function(mob)
        ESP(mob)
    end)
end

-- Disconnect ESP
function ZygHubV4ESP:DisconnectESP()
    if self._addedConnection then
        self._addedConnection:Disconnect()
        self._addedConnection = nil
    end
    -- Destroy drawings
    for _, obj in pairs(Drawing:GetObjects()) do
        obj:Remove()
    end
end

return ZygHubV4ESP
