--// ZygHub Chatlogger (with UI toggle support)
-- Call Chatlogger:SetVisible(true/false) to show/hide the UI

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local ZygHubChatlogger = {}
ZygHubChatlogger.__index = ZygHubChatlogger

function ZygHubChatlogger.new()
    local self = setmetatable({}, ZygHubChatlogger)

    self._running = false
    self._lines = {}
    self._connections = {}
    self._gui = nil
    self._frame = nil
    self._chatBox = nil
    self._header = nil
    self._visible = false -- default hidden

    return self
end

function ZygHubChatlogger:Load()
    if self._running then return end
    self._running = true

    -- Create GUI
    local gui = Instance.new("ScreenGui")
    gui.Name = "ChatLoggerUI"
    gui.ResetOnSpawn = false
    gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    -- Main frame
    local frame = Instance.new("Frame")
    frame.Name = "MainFrame"
    frame.Size = UDim2.new(0, 500, 0, 300)
    frame.Position = UDim2.new(0.3, 0, 0.3, 0)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.BackgroundTransparency = 0.3
    frame.Active = true
    frame.Draggable = true
    frame.Parent = gui

    -- Rounded corners
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame

    -- Header
    local header = Instance.new("TextLabel")
    header.Name = "Header"
    header.Size = UDim2.new(1, 0, 0, 30)
    header.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    header.BackgroundTransparency = 0.2
    header.Text = "Chat Logger"
    header.TextColor3 = Color3.fromRGB(255, 255, 255)
    header.TextSize = 18
    header.Font = Enum.Font.SourceSansBold
    header.Parent = frame

    local headerCorner = Instance.new("UICorner")
    headerCorner.CornerRadius = UDim.new(0, 10)
    headerCorner.Parent = header

    -- Chat box
    local chatBox = Instance.new("TextLabel")
    chatBox.Name = "ChatBox"
    chatBox.Size = UDim2.new(1, -10, 1, -40)
    chatBox.Position = UDim2.new(0, 5, 0, 35)
    chatBox.BackgroundTransparency = 1
    chatBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    chatBox.TextSize = 16
    chatBox.Font = Enum.Font.SourceSans
    chatBox.TextXAlignment = Enum.TextXAlignment.Left
    chatBox.TextYAlignment = Enum.TextYAlignment.Top
    chatBox.TextWrapped = true
    chatBox.Text = ""
    chatBox.Parent = frame

    self._gui = gui
    self._frame = frame
    self._chatBox = chatBox
    self._header = header

    -- start hidden
    self:SetVisible(false)

    -- Bind chat messages
    local function shift(tbl)
        for i = 1, #tbl do
            tbl[i - 1] = tbl[i]
        end
        tbl[#tbl] = nil
    end

    local function updateChat()
        chatBox.Text = table.concat(self._lines, "\n")
    end

    local function chatbind(player)
        local conn = player.Chatted:Connect(function(msg)
            local firstname = player:GetAttribute("FirstName") or ""
            local lastname = player:GetAttribute("LastName") or ""
            table.insert(self._lines, string.format("%s %s (%s): %s", firstname, lastname, player.Name, msg))
            if #self._lines >= 17 then
                shift(self._lines)
            end
            updateChat()
        end)
        table.insert(self._connections, conn)
    end

    for _, player in ipairs(Players:GetPlayers()) do
        chatbind(player)
    end
    table.insert(self._connections, Players.PlayerAdded:Connect(chatbind))
end

function ZygHubChatlogger:SetVisible(state)
    self._visible = state
    if self._frame then
        self._frame.Visible = state
    end
end

function ZygHubChatlogger:Unload()
    if not self._running then return end
    self._running = false

    if self._gui then
        self._gui:Destroy()
        self._gui = nil
    end

    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    self._connections = {}
    self._lines = {}
end

-- return instance
return ZygHubChatlogger
