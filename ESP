--// HELPER: detect "random string name" (letters + numbers)
local function IsRandomName(name)
    return name:match("%d") and name:match("%a") and #name >= 6
end

--// RANDOM-NAME OBJECT ESP (Type2)
local function ObjectESP(obj)
    local box = NewQuad(Settings.Box_Thickness, Settings.Box_Color)

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if obj and obj.Parent and obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
            local hrp = obj.HumanoidRootPart
            local vector, onScreen = camera:WorldToViewportPoint(hrp.Position)

            if onScreen then
                local size = 50
                box.PointA = Vector2.new(vector.X - size, vector.Y - size)
                box.PointB = Vector2.new(vector.X + size, vector.Y - size)
                box.PointC = Vector2.new(vector.X + size, vector.Y + size)
                box.PointD = Vector2.new(vector.X - size, vector.Y + size)
                box.Visible = true
            else
                box.Visible = false
            end
        else
            box.Visible = false
            conn:Disconnect()
            box:Remove()
        end
    end)
end

--// INIT
if Settings.Type == 1 then
    -- Player ESP
    for _, v in pairs(game:GetService("Players"):GetPlayers()) do
        if v ~= player then
            coroutine.wrap(PlayerESP)(v)
        end
    end
    game.Players.PlayerAdded:Connect(function(newplr)
        if newplr ~= player then
            coroutine.wrap(PlayerESP)(newplr)
        end
