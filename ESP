elseif Settings.Type == 2 then
    -- Random-name ESP
    for _, obj in pairs(workspace:GetDescendants()) do
        if IsRandomName(obj.Name) and obj:IsA("Model") then
            coroutine.wrap(ObjectESP)(obj)
        end
    end
    workspace.DescendantAdded:Connect(function(obj)
        if IsRandomName(obj.Name) and obj:IsA("Model") then
            coroutine.wrap(ObjectESP)(obj)
        end
    end)
end
