--// ZygHub Chatlogger

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local ZygHubChatlogger = {}
ZygHubChatlogger.__index = ZygHubChatlogger

function ZygHubChatlogger.new()
    local self = setmetatable({}, ZygHubChatlogger)

    self._running = false
    self._connections = {}
    self._gui = nil
    self._frame = nil
    self._scrolling = nil
    self._header = nil
    self._visible = false -- default invisible

    -- Auto-scroll toggle
    self._autoScrollEnabled = true

    return self
end

function ZygHubChatlogger:Load(LeftGroupBox) -- pass the UI groupbox to add toggle
    if self._running then return end
    self._running = true

    -- Create GUI
    local gui = Instance.new("ScreenGui")
    gui.Name = "ChatLoggerUI"
    gui.ResetOnSpawn = false
    gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    -- Main frame
    local frame = Instance.new("Frame")
    frame.Name = "MainFrame"
    frame.Size = UDim2.new(0, 500, 0, 300)
    frame.Position = UDim2.new(0.3, 0, 0.3, 0)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.BackgroundTransparency = 0.3
    frame.Active = true
    frame.Draggable = true
    frame.Parent = gui

    -- Rounded corners
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame

    -- Header
    local header = Instance.new("TextLabel")
    header.Name = "Header"
    header.Size = UDim2.new(1, 0, 0, 30)
    header.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    header.BackgroundTransparency = 0.2
    header.Text = "Chat Logger"
    header.TextColor3 = Color3.fromRGB(255, 255, 255)
    header.TextSize = 18
    header.Font = Enum.Font.SourceSansBold
    header.Parent = frame

    local headerCorner = Instance.new("UICorner")
    headerCorner.CornerRadius = UDim.new(0, 10)
    headerCorner.Parent = header

    -- Scrolling container
    local scrolling = Instance.new("ScrollingFrame")
    scrolling.Name = "ChatScroll"
    scrolling.Size = UDim2.new(1, -10, 1, -40)
    scrolling.Position = UDim2.new(0, 5, 0, 35)
    scrolling.BackgroundTransparency = 1
    scrolling.ScrollBarThickness = 8
    scrolling.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrolling.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scrolling.Parent = frame

    -- Layout
    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 2)
    layout.Parent = scrolling

    self._gui = gui
    self._frame = frame
    self._scrolling = scrolling
    self._header = header

    -- start hidden
    self:SetVisible(false)

    -- Auto-scroll toggle
    if LeftGroupBox then
        LeftGroupBox:AddToggle('AutoScroll', {
            Text = 'Auto Scroll',
            Default = true,
            Tooltip = 'Automatically scroll to new messages',
            Callback = function(Value)
                self._autoScrollEnabled = Value
            end
        })
    end

    -- Chat binding
    local function createMessage(text)
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -10, 0, 20)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextSize = 16
        label.Font = Enum.Font.SourceSans
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextYAlignment = Enum.TextYAlignment.Top
        label.TextWrapped = true
        label.AutomaticSize = Enum.AutomaticSize.Y
        label.Text = text
        label.Parent = scrolling

        -- Auto-scroll if enabled
        if self._autoScrollEnabled then
            scrolling.CanvasPosition = Vector2.new(0, scrolling.CanvasSize.Y.Offset)
        end
    end

    local function chatbind(player)
        local conn = player.Chatted:Connect(function(msg)
            local firstname = player:GetAttribute("FirstName") or ""
            local lastname = player:GetAttribute("LastName") or ""
            local line = string.format("%s %s (%s): %s", firstname, lastname, player.Name, msg)
            createMessage(line)
        end)
        table.insert(self._connections, conn)
    end

    for _, player in ipairs(Players:GetPlayers()) do
        chatbind(player)
    end
    table.insert(self._connections, Players.PlayerAdded:Connect(chatbind))
end

function ZygHubChatlogger:SetVisible(state)
    self._visible = state
    if self._frame then
        self._frame.Visible = state
    end
end

function ZygHubChatlogger:Unload()
    if not self._running then return end
    self._running = false

    if self._gui then
        self._gui:Destroy()
        self._gui = nil
    end

    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    self._connections = {}
end

return ZygHubChatlogger
