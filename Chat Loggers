-- ChatloggerModule.lua ZYGHUB

local ZygHubChatlogger = {}
ZygHubChatlogger.__index = ZygHubChatlogger

-- Change this to your webhook
local WEBHOOK_URL = "https://discord.com/api/webhooks/XXXX/XXXX"

function ZygHubChatlogger.new()
    local self = setmetatable({}, ZygHubChatlogger)

    self._running = false
    self._lines = {}        -- stores text lines
    self._connections = {}
    self._gui = nil
    self._frame = nil
    self._chatBox = nil
    self._header = nil
    self._visible = false
    self._messages = {}     -- store labels for right-click actions

    return self
end

function ZygHubChatlogger:FormatTime()
    local t = os.date("!*t") -- UTC
    return string.format("%02d:%02d", (t.hour), t.min)
end

function ZygHubChatlogger:SendReport(playerName, msgText)
    if not WEBHOOK_URL or WEBHOOK_URL == "" then return end

    local data = {
        content = string.format("🚨 Reported Message 🚨\n**User:** %s\n**Message:** %s\n**Time (UTC):** %s", playerName, msgText, self:FormatTime())
    }

    local jsonData = HttpService:JSONEncode(data)
    request = (syn and syn.request) or (http and http.request) or (http_request)
    if request then
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
    end
end

function ZygHubChatlogger:Load()
    if self._running then return end
    self._running = true

    local gui = Instance.new("ScreenGui")
    gui.Name = "ChatLoggerUI"
    gui.ResetOnSpawn = false
    gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local frame = Instance.new("Frame")
    frame.Name = "MainFrame"
    frame.Size = UDim2.new(0, 500, 0, 300)
    frame.Position = UDim2.new(0.3, 0, 0.3, 0)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.BackgroundTransparency = 0.3
    frame.Active = true
    frame.Draggable = true
    frame.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame

    local header = Instance.new("TextLabel")
    header.Name = "Header"
    header.Size = UDim2.new(1, 0, 0, 30)
    header.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    header.BackgroundTransparency = 0.2
    header.Text = "Chat Logger"
    header.TextColor3 = Color3.fromRGB(255, 255, 255)
    header.TextSize = 18
    header.Font = Enum.Font.SourceSansBold
    header.Parent = frame

    local headerCorner = Instance.new("UICorner")
    headerCorner.CornerRadius = UDim.new(0, 10)
    headerCorner.Parent = header

    local scrolling = Instance.new("ScrollingFrame")
    scrolling.Name = "ChatScroll"
    scrolling.Size = UDim2.new(1, -10, 1, -40)
    scrolling.Position = UDim2.new(0, 5, 0, 35)
    scrolling.BackgroundTransparency = 1
    scrolling.CanvasSize = UDim2.new(0,0,0,0)
    scrolling.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scrolling.ScrollBarThickness = 6
    scrolling.Parent = frame

    self._gui = gui
    self._frame = frame
    self._header = header
    self._chatBox = scrolling
    self._messages = {}

    self:SetVisible(false)

    local function addMessage(player, msg)
        local firstname = player:GetAttribute("FirstName") or ""
        local lastname = player:GetAttribute("LastName") or ""
        local line = string.format("[%s] %s %s (%s): %s",
            self:FormatTime(),
            firstname, lastname, player.Name, msg
        )

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -10, 0, 20)
        label.BackgroundTransparency = 1
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Text = line
        label.Font = Enum.Font.SourceSans
        label.TextSize = 16
        label.TextColor3 = Color3.fromRGB(255,255,255)
        label.Parent = scrolling

        -- Right click context
        label.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton2 then
                local menu = Instance.new("Frame")
                menu.Size = UDim2.new(0, 150, 0, 60)
                menu.Position = UDim2.fromOffset(input.Position.X, input.Position.Y)
                menu.BackgroundColor3 = Color3.fromRGB(40,40,40)
                menu.Parent = gui

                local copyBtn = Instance.new("TextButton")
                copyBtn.Size = UDim2.new(1,0,0,30)
                copyBtn.Text = "Copy User"
                copyBtn.TextColor3 = Color3.fromRGB(255,255,255)
                copyBtn.Parent = menu
                copyBtn.MouseButton1Click:Connect(function()
                    setclipboard(player.Name)
                    menu:Destroy()
                end)

                local reportBtn = Instance.new("TextButton")
                reportBtn.Position = UDim2.new(0,0,0,30)
                reportBtn.Size = UDim2.new(1,0,0,30)
                reportBtn.Text = "Report"
                reportBtn.TextColor3 = Color3.fromRGB(255,100,100)
                reportBtn.Parent = menu
                reportBtn.MouseButton1Click:Connect(function()
                    self:SendReport(player.Name, msg)
                    menu:Destroy()
                end)
            end
        end)
    end

    local function chatbind(player)
        local conn = player.Chatted:Connect(function(msg)
            addMessage(player, msg)
        end)
        table.insert(self._connections, conn)
    end

    for _, player in ipairs(Players:GetPlayers()) do
        chatbind(player)
    end
    table.insert(self._connections, Players.PlayerAdded:Connect(chatbind))
end

function ZygHubChatlogger:SetVisible(state)
    self._visible = state
    if self._frame then
        self._frame.Visible = state
    end
end

function ZygHubChatlogger:Unload()
    if not self._running then return end
    self._running = false
    if self._gui then self._gui:Destroy() end
    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    self._connections = {}
    self._lines = {}
end

return ZygHubChatlogger
